---
import { getHreflangEntries, getXDefaultHref } from "@/shared/lib/i18n/locales";

interface Props {
  path: string;
  isMultilingual?: boolean;
}

const { path, isMultilingual = true } = Astro.props;
const site = Astro.site?.origin ?? "";
const entries = isMultilingual ? getHreflangEntries(path) : [];
const xDefault = isMultilingual ? getXDefaultHref(path) : null;
---

{isMultilingual && entries.map(({ locale, href }) => (
  <link rel="alternate" hreflang={locale} href={`${site}${href}`} />
))}
{isMultilingual && xDefault && (
  <link rel="alternate" hreflang="x-default" href={`${site}${xDefault}`} />
)}
