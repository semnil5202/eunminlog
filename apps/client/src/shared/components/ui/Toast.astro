---
/** 전역 토스트 알림. Layout에 1회 삽입한다. data-toast 속성이 있는 요소 클릭 시 자동 표시. */
---

<div
  id="toast"
  class="fixed left-1/2 z-50 -translate-x-1/2 rounded-lg bg-gray-800 px-4 py-3 text-sm text-white whitespace-pre-line text-center opacity-0 shadow-lg transition-all duration-300 pointer-events-none bottom-6 lg:bottom-auto lg:top-6 translate-y-4 lg:-translate-y-4"
  role="alert"
  aria-live="polite"
>
  <span id="toast-message"></span>
</div>

<script>
  const toast = document.getElementById("toast")!;
  const toastMessage = document.getElementById("toast-message")!;
  let timer: ReturnType<typeof setTimeout>;

  const showToast = (message: string) => {
    clearTimeout(timer);
    toastMessage.textContent = message;

    toast.classList.remove("translate-y-4", "lg:-translate-y-4", "opacity-0", "pointer-events-none");
    toast.classList.add("translate-y-0", "lg:translate-y-0", "opacity-100");

    timer = setTimeout(() => {
      toast.classList.add("translate-y-4", "lg:-translate-y-4", "opacity-0", "pointer-events-none");
      toast.classList.remove("translate-y-0", "lg:translate-y-0", "opacity-100");
    }, 2500);
  };

  document.addEventListener("click", (e) => {
    const target = (e.target as HTMLElement).closest<HTMLElement>("[data-toast]");
    if (target) {
      showToast(target.dataset.toast!);
    }
  });
</script>
