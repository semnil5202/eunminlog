---
/** 한국어 홈 페이지 (/) */

import ListLayout from "@/layouts/ListLayout.astro";
import PostCardGrid from "@/features/post-feed/components/PostCardGrid.astro";
import BreadcrumbJsonLd from "@/shared/components/seo/BreadcrumbJsonLd.astro";
import { DEFAULT_LOCALE } from "@/shared/types/common";
import type { LocalizedPost } from "@/shared/types/post";
import { getPaginatedPosts, getSponsoredPosts } from "@/features/post-feed/api/posts";
import { t } from "@/shared/lib/i18n/translations";

const locale = DEFAULT_LOCALE;

const [{ posts: rawPosts, totalPages }, sponsored] = await Promise.all([
  getPaginatedPosts(1),
  getSponsoredPosts(),
]);

const posts: LocalizedPost[] = rawPosts.map((p) => ({ ...p, translated_place_name: null, translated_address: null, translated_product_name: null, translated_purchase_source: null, translated_price_prefix: null, locale }));
const sponsoredLocalized: LocalizedPost[] = sponsored.map((p) => ({ ...p, translated_place_name: null, translated_address: null, translated_product_name: null, translated_purchase_source: null, translated_price_prefix: null, locale }));

const breadcrumbItems = [{ name: "홈", url: "/" }];
---

<ListLayout
  title={t("meta.homeTitle", locale)}
  description={t("meta.homeDescription", locale)}
  canonical="/"
  path="/"
  locale={locale}
  ogImage="https://media.eunminlog.site/statics/images/og_image_main.webp"
  sponsoredPosts={sponsoredLocalized}
  gaPageParams={{ page_type: 'list', content_category: 'all', content_sub_category: 'all', content_locale: locale }}
>
  <BreadcrumbJsonLd slot="head" items={breadcrumbItems} />

  <PostCardGrid
    posts={posts}
    locale={locale}
    feedEndpoint={`/api/feed/${locale}/all/`}
    hasNextPage={totalPages > 1}
    sponsoredLabel={t("post.sponsored", locale)}
  />
</ListLayout>
