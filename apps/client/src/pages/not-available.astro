---
/** 다국어 미지원 포스트 접근 시 fallback 페이지 (/not-available/) */

import Layout from "@/layouts/Layout.astro";
import { SITE_NAME_KO } from "@eunmin-log/config/site";
import { LOCALES, DEFAULT_LOCALE } from "@/shared/types/common";
import { t } from "@/shared/lib/i18n/translations";

const translations = Object.fromEntries(
  LOCALES.map((locale) => [
    locale,
    {
      title: t("i18n.unavailable", locale),
      description: t("i18n.unavailableDescription", locale),
      viewInKorean: t("i18n.viewInKorean", locale),
      goHome: t("error.goHome", locale),
    },
  ])
);
---

<Layout
  title={`다국어 미지원 - ${SITE_NAME_KO}`}
  description="이 글은 다국어를 지원하지 않습니다."
  canonical="/not-available/"
  path="/not-available/"
  gaPageParams={{ page_type: "unavailable", content_locale: "ko" }}
  isMultilingual={false}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <main class="flex grow flex-col items-center justify-center px-4 text-center">
    <p class="text-6xl font-bold text-primary-600">—</p>
    <h1 id="unavailable-title" class="mt-4 text-2xl font-semibold text-gray-900">
      이 글은 다국어를 지원하지 않습니다.
    </h1>
    <p id="unavailable-description" class="mt-2 text-gray-500">
      이 콘텐츠는 한국어로만 제공됩니다.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <a
        id="unavailable-korean"
        href="/"
        class="inline-block rounded-lg bg-primary-600 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700"
      >
        한국어로 보기
      </a>
      <a
        id="unavailable-home"
        href="/"
        class="inline-block rounded-lg border border-gray-300 px-6 py-3 text-base font-semibold text-gray-700 transition-colors hover:bg-gray-50"
      >
        메인페이지로 이동하기
      </a>
    </div>
  </main>

  <script is:inline define:vars={{ translations, LOCALES, DEFAULT_LOCALE }}>
    const path = window.location.pathname;
    const segment = path.split("/")[1] || "";
    const locale = LOCALES.includes(segment) ? segment : DEFAULT_LOCALE;
    const tr = translations[locale] || translations[DEFAULT_LOCALE];

    document.getElementById("unavailable-title").textContent = tr.title;
    document.getElementById("unavailable-description").textContent = tr.description;

    const koreanLink = document.getElementById("unavailable-korean");
    koreanLink.textContent = tr.viewInKorean;

    const homeLink = document.getElementById("unavailable-home");
    homeLink.textContent = tr.goHome;
    homeLink.href = locale === DEFAULT_LOCALE ? "/" : `/${locale}/`;

    document.documentElement.lang = locale;
  </script>
</Layout>
