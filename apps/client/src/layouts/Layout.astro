---
import { GA_MEASUREMENT_ID, SITE_NAME_EN } from "@eunminlog/config/site";
import BaseHead from "@/shared/components/layout/BaseHead.astro";
import Header from "@/shared/components/layout/Header.astro";
import Footer from "@/shared/components/layout/Footer.astro";
import Toast from "@/shared/components/ui/Toast.astro";
import ImageLightbox from "@/shared/components/ui/ImageLightbox.astro";
import JsonLd from "@/shared/components/seo/JsonLd.astro";
import type { Locale } from "@/shared/types/common";
import { DEFAULT_LOCALE } from "@/shared/types/common";
import { t } from "@/shared/lib/i18n/translations";

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  locale?: Locale;
  path: string;
  type?: "website" | "article";
  gaPageParams?: Record<string, string | number | boolean>;
  isMultilingual?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  locale = DEFAULT_LOCALE,
  path,
  type = "website",
  gaPageParams = {},
  isMultilingual = true,
} = Astro.props;

const isProduction = import.meta.env.PUBLIC_STAGE === 'production';
const robotsContent = isProduction ? 'index, follow' : 'noindex, nofollow';

const siteOrigin = Astro.site?.origin ?? "";
const siteName = t("meta.siteName", locale);
const webSiteSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  ...(siteName !== SITE_NAME_EN && { "alternateName": SITE_NAME_EN }),
  "url": `${siteOrigin}/`,
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      locale={locale}
      path={path}
      type={type}
      isMultilingual={isMultilingual}
    />
    <link rel="preload" href="https://media.eunminlog.site/fonts/Pretendard-Regular.subset.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://media.eunminlog.site/fonts/Pretendard-SemiBold.subset.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://media.eunminlog.site/fonts/Pretendard-Bold.subset.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="robots" content={robotsContent} />
    <JsonLd schema={webSiteSchema} />
    <slot name="head" />
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ GA_MEASUREMENT_ID, gaPageParams }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID, gaPageParams);
    </script>
    <script async src="https://wcs.pstatic.net/wcslog.js"></script>
    <script is:inline>
      if (!window.wcs_add) window.wcs_add = {};
      wcs_add["wa"] = "c8876b6e46c848";
      if (window.wcs) wcs_do();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-white text-gray-900 antialiased font-pretendard">
    <Header locale={locale} path={path} isMultilingual={isMultilingual} />
    <slot />
    <Footer locale={locale} />
    <Toast />
    <ImageLightbox locale={locale} />
  </body>
</html>
